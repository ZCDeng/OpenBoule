# ── Boule 环境变量样板 ──
# 复制为 .env 并填值。.env 已被 .gitignore 忽略，绝不入库。

# ── Postgres（状态机真值源 + SSE 回放日志）──
POSTGRES_USER=boule
POSTGRES_PASSWORD=boule_dev_pw_change_me
POSTGRES_DB=boule
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# 应用用的连接串（容器内 host=postgres，本机跑迁移 host=localhost）
DATABASE_URL=postgres://boule:boule_dev_pw_change_me@localhost:5432/boule

# ── Redis ──
# 关键隔离（KTD-19）：BullMQ 用 DB 0；nonce 撤销集 + 单写者分布式锁用 DB 1。
# 单实例开 AOF（appendonly yes）持久化，避免 BullMQ 操作连带丢失已撤销 nonce。
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_BULLMQ_DB=0
REDIS_SECURITY_DB=1

# ── 真值源（U2）──
# repo 是私有的 → token 强制（非仅防限流）。生产用 fine-grained 只读单仓 Contents PAT。
# 本机开发可用 `gh auth token` 的值；raw.githubusercontent.com 读私有文件必须带此 token。
GITHUB_TOKEN=
TRUTH_SOURCE_REPO=ZCDeng/consulting-team
TRUTH_SOURCE_BRANCH=main

# ── Agent SDK / Anthropic（U3）──
# headless worker 必须有真 key（apiKeySource=user）；不进 BullMQ job payload / DB，日志经 log-scrubber 脱敏。
# 本机开发可不配 key，走 Claude CLI 订阅会话（apiKeySource=none，KTD-2）。
ANTHROPIC_API_KEY=

# ── Agent 运行策略（U3/U4）──
# 无事件 watchdog（ms）。researcher 联网检索慢，默认 300s（原 120s 对 web 抓取过紧）。
AGENT_WATCHDOG_MS=300000
# Aditly 自托管 MCP（web 检索网关，外部依赖项目 ZCDeng/Aditly，需另跑其 compose 在 :8643）。
# 本机直跑 api 用 127.0.0.1；容器内用 host.docker.internal。设为 off 关闭 researcher 联网（降级 + 标注未联网）。
ADITLY_MCP_URL=http://127.0.0.1:8643/mcp/

# ── 认证（U6）──
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── 应用 ──
NODE_ENV=development
API_PORT=3000

# ── Reference PDF OCR（liteparse 本地 Tesseract）──
# 数字 PDF 仍走 pdfjs；仅扫描/图像型 PDF 进入 liteparse OCR。
TESSDATA_PREFIX=/opt/tessdata
BOULE_OCR_LANGUAGE=chi_sim+eng
BOULE_OCR_MAX_PAGES=100
BOULE_OCR_DPI=200
BOULE_OCR_CONFIDENCE_THRESHOLD=0.55
BOULE_STORE_ORIGINAL_CONFIDENCE_THRESHOLD=0.85
# 默认 none：liteparse 空/低置信则 fail-loud；设 claude 才会把该文件发给 Claude 兜底。
BOULE_OCR_FALLBACK=none
# BOULE_ENABLE_CLAUDE_REFERENCE_OCR=1  # 已废弃：等同 BOULE_OCR_FALLBACK=claude；新部署请用 BOULE_OCR_FALLBACK
